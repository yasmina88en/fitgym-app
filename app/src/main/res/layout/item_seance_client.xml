<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- Image séance -->
        <ImageView
            android:id="@+id/ivSessionImage"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:scaleType="centerCrop"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/placeholder" />

        <!-- Heart favorite (top-left over image) -->
        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignTop="@id/ivSessionImage"
            android:layout_toEndOf="@id/ivSessionImage"
            android:layout_marginStart="-40dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:src="@drawable/ic_heart_outline"
            android:contentDescription="Favoris" />

        <!-- Right content -->
        <LinearLayout
            android:id="@+id/llInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/ivSessionImage"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTitre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Yoga Vinyasa Flow"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvPrix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25€"
                    android:textColor="#2563EB"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- chips catégorie & niveau (simples TextViews stylés) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvCategorieChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:background="@drawable/chip_bg_gray"
                    android:text="Yoga"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvNiveauChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:background="@drawable/bg_badge_violet"
                    android:text="Intermédiaire"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Coach -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_user" />

                <TextView
                    android:id="@+id/tvCoach"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sarah Martin"
                    android:layout_marginStart="6dp"
                    android:textSize="14sp"
                    android:textColor="#374151"/>
            </LinearLayout>

            <!-- date & heure -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar" />

                <TextView
                    android:id="@+id/tvDateHeure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mer. 5 nov • 09:00"
                    android:layout_marginStart="6dp"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <!-- rating + availability warning -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_star" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.8 (124)"
                    android:layout_marginStart="6dp"
                    android:textSize="13sp"
                    android:textColor="#FF9800"/>

                <TextView
                    android:id="@+id/tvWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ⚠️ Plus que 3 places"
                    android:layout_marginStart="12dp"
                    android:textSize="13sp"
                    android:textColor="#9C27B0"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
