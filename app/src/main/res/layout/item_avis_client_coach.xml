<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Avatar du client -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/avatarClient"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/avatar_placeholder"
            app:civ_border_width="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Nom du client -->
        <TextView
            android:id="@+id/nomClient"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Nom Client"
            android:textColor="#1F2937"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/dateAvis"
            app:layout_constraintEnd_toStartOf="@+id/layoutStarsAvis"
            app:layout_constraintStart_toEndOf="@+id/avatarClient"
            app:layout_constraintTop_toTopOf="@+id/avatarClient"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Date de l'avis -->
        <TextView
            android:id="@+id/dateAvis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="01 Jan 2025"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/avatarClient"
            app:layout_constraintStart_toEndOf="@+id/avatarClient"
            app:layout_constraintTop_toBottomOf="@+id/nomClient" />

        <!-- Étoiles (Rating) -->
        <LinearLayout
            android:id="@+id/layoutStarsAvis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/nomClient"
            app:layout_constraintBottom_toBottomOf="@+id/nomClient"/>

        <!-- Séparateur subtil (optionnel) -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#F3F4F6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/avatarClient" />

        <!-- Commentaire -->
        <TextView
            android:id="@+id/commentaire"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"
            android:text="Ceci est un commentaire exemple qui montre comment le texte s'affiche dans la nouvelle carte moderne."
            android:textColor="#4B5563"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>