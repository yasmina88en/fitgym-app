<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <!-- HEADER MODERNE -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Fond avec dégradé et courbe (optionnel via shape) -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/gradient_header"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Bouton Retour -->
            <ImageButton
                android:id="@+id/btnRetour"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:background="@drawable/circle_white_transparent"
                android:src="@drawable/ic_back"
                android:padding="12dp"
                app:tint="@android:color/white"
                android:elevation="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Photo du Coach (centrée et plus grande) -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imageCoach"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginTop="60dp"
                android:src="@drawable/coach_placeholder"
                app:civ_border_width="4dp"
                app:civ_border_color="@android:color/white"
                android:elevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Nom du Coach -->
            <TextView
                android:id="@+id/nomCoach"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sarah Martin"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:elevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imageCoach" />

            <!-- Note et Avis -->
            <LinearLayout
                android:id="@+id/ratingContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rating_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="8dp"
                android:elevation="4dp"
                app:layout_constraintTop_toBottomOf="@+id/nomCoach"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_star_filled"
                    app:tint="#FFD700"/>

                <TextView
                    android:id="@+id/ratingCoach"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.9"
                    android:textColor="#333"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/nbAvis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (234 avis)"
                    android:textColor="#666"
                    android:textSize="12sp"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Contenu Principal qui chevauche légèrement le header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="-20dp">

            <!-- Carte Spécialités -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spécialités"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/layoutSpecialites"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Carte À Propos -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="À propos"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/descriptionCoach"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Description du coach..."
                        android:textSize="14sp"
                        android:textColor="#4B5563"
                        android:lineSpacingExtra="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section Séances -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Séances disponibles"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSeances"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                android:layout_marginBottom="16dp"/>

            <!-- Section Avis -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avis des clients"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_marginStart="4dp"/>

                <Button
                    android:id="@+id/btnRate1"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Noter"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:background="@drawable/btn_rounded_primary"
                    android:paddingHorizontal="20dp"
                    android:textSize="14sp"
                    android:elevation="2dp"/>
            </LinearLayout>

            <!-- Liste des Avis -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAvis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Layout invisible pour garder la référence (si nécessaire pour le code Java existant) -->
            <LinearLayout
                android:id="@+id/layoutStarsCoach"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
