<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@android:color/white"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Photo du Coach -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/coachAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/coach_placeholder"
            app:civ_border_width="2dp"
            app:civ_border_color="#F3F4F6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Infos Principales -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/coachAvatar"
            app:layout_constraintTop_toTopOf="@+id/coachAvatar"
            app:layout_constraintBottom_toBottomOf="@+id/coachAvatar">

            <TextView
                android:id="@+id/coachName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom du Coach"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Note et Avis -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_star_filled"
                    app:tint="#FBBF24" />

                <TextView
                    android:id="@+id/coachRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.8"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/coachReviewCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(120 avis)"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/coachAvatar" />

        <!-- Description -->
        <TextView
            android:id="@+id/coachDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Description courte du coach..."
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <!-- Spécialités -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSpecialties"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleLine="true"
            app:layout_constraintTop_toBottomOf="@+id/coachDescription" />

        <!-- Bouton Noter (plus discret) -->
        <Button
            android:id="@+id/btnRate"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Noter"
            android:textColor="#6D28D9"
            android:textSize="12sp"
            app:icon="@drawable/ic_star"
            app:iconTint="#6D28D9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/chipGroupSpecialties" />

        <!-- Layout invisible pour garder la compatibilité Java -->
        <LinearLayout
            android:id="@+id/layoutStarsCoach"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>